rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===== פונקציות עזר =====
    function isSignedIn() {
      return request.auth != null;
    }

    function memberRef(hid) {
      return /databases/$(database)/documents/households/$(hid)/members/$(request.auth.uid);
    }

    function isMember(hid) {
      return isSignedIn() && exists(memberRef(hid));
    }

    function memberData(hid) {
      return get(memberRef(hid)).data;
    }

    function isOwner(hid) {
      return isMember(hid) && memberData(hid).isOwner == true;
    }

    // בעל החשבון מקבל כל הרשאה אוטומטית
    function perm(hid, key) {
      return isOwner(hid) ||
        (isMember(hid) && memberData(hid).permissions[key] == true);
    }

    function householdData(hid) {
      return get(/databases/$(database)/documents/households/$(hid)).data;
    }

    // ===== משתמשים =====
    match /users/{uid} {
      // מזוהים יכולים לקרוא פרטי משתמש בסיסיים (לצורך תצוגת שמות)
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == uid;

      // רשומות החברות הפרטיות של המשתמש (מקור האמת ל"החשבונות שלי")
      match /memberships/{hid} {
        allow read, write: if isSignedIn() && request.auth.uid == uid;
      }
    }

    // ===== חשבונות משפחתיים =====
    match /households/{hid} {
      allow read: if isMember(hid);
      allow create: if isSignedIn() &&
        request.resource.data.ownerId == request.auth.uid;
      // עדכון החשבון (כולל שיטת נקודות ואיפוס) - בעלים או מנהל או מי שרשאי לאפס נקודות
      allow update: if isOwner(hid) ||
        perm(hid, 'canManageMembers') ||
        perm(hid, 'canResetPoints');
      allow delete: if isOwner(hid);

      // ----- חברים -----
      match /members/{uid} {
        allow read: if isMember(hid);

        // יצירה: מנהל עם הרשאת ניהול, או המשתמש עצמו
        // (בעת יצירת חשבון הוא הבעלים; בקבלת הזמנה הוא חבר רגיל).
        // הערה: אכיפת קיום הזמנה תואמת לצירוף-עצמי היא הקשחה עתידית
        // (דורשת מזהי הזמנה דטרמיניסטיים או Cloud Function).
        allow create: if isSignedIn() && (
          perm(hid, 'canManageMembers') ||
          (request.auth.uid == uid && (
            request.resource.data.isOwner == false ||
            householdData(hid).ownerId == request.auth.uid
          ))
        );

        // עריכה: מנהל (על חבר שאינו בעל החשבון), או המשתמש עצמו - שם התצוגה בלבד
        allow update: if
          (perm(hid, 'canManageMembers') && resource.data.isOwner == false) ||
          (request.auth.uid == uid &&
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['displayName']));
        allow delete: if (perm(hid, 'canManageMembers') &&
          resource.data.isOwner == false) ||
          request.auth.uid == uid;
      }

      // ----- רשומות ביצוע (לצבירת נקודות) -----
      match /completions/{cid} {
        allow read: if isMember(hid);
        allow create: if isMember(hid) &&
          request.resource.data.actorId == request.auth.uid;
        allow update: if false; // רשומות ביצוע אינן ניתנות לשינוי
        // מחיקה נדרשת בעת פתיחת משימה מחדש (הפחתת נקודות)
        allow delete: if isMember(hid);
      }

      // ----- משימות -----
      match /tasks/{tid} {
        allow read: if isMember(hid);
        allow create: if perm(hid, 'canCreateTasks');

        // עריכה מלאה למי שיש לו canEditTasks;
        // או עדכון שדות סטטוס בלבד למי שרשאי לסמן את המשימה כבוצעה.
        allow update: if perm(hid, 'canEditTasks') ||
          (onlyCompletionFields() && canCompleteTask(hid, tid));

        allow delete: if perm(hid, 'canDeleteTasks');

        function onlyCompletionFields() {
          return request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'completedBy', 'completedAt', 'dueDate']);
        }

        function canCompleteTask(hid2, tid2) {
          return isMember(hid2) && (
            isOwner(hid2) ||
            memberData(hid2).permissions.canCompleteAnyTask == true ||
            request.auth.uid in get(
              /databases/$(database)/documents/households/$(hid2)/tasks/$(tid2)
            ).data.assigneeIds
          );
        }

        // ----- היסטוריית משימה -----
        match /history/{eid} {
          allow read: if isMember(hid);
          allow create: if isMember(hid);
          allow update: if false; // אירועי היסטוריה אינם ניתנים לשינוי
          allow delete: if perm(hid, 'canDeleteTasks');
        }
      }
    }

    // ===== הזמנות (מבוססות-קישור) =====
    // מזהה ההזמנה הוא אקראי ובלתי-ניחוש (Firestore auto-id), ומשמש כ"סוד"
    // שבקישור. לכן כל משתמש מזוהה שמחזיק בקישור רשאי לקרוא ולאשר את ההזמנה.
    match /invitations/{invId} {
      // קריאת הזמנה בודדת לפי מזהה (המזהה הוא הסוד שבקישור) - מותרת גם
      // לפני התחברות, כדי שהמוזמן יראה את פרטי ההזמנה ויוכל להירשם.
      allow get: if true;
      // שאילתות (list) דורשות התחברות (למשל טעינת ההזמנות של המשתמש).
      allow list: if isSignedIn();
      allow create: if isSignedIn() &&
        perm(request.resource.data.householdId, 'canManageMembers');
      // עדכון סטטוס (accepted/declined) ע"י מי שמצטרף דרך הקישור, או ניהול ע"י מנהל
      allow update: if isSignedIn();
      allow delete: if isSignedIn() &&
        perm(resource.data.householdId, 'canManageMembers');
    }
  }
}
